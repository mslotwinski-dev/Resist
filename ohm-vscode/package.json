{
  "name": "ohm-lang",
  "displayName": "Ohm Language",
  "description": "Syntax highlighting and language support for ResistScript (.ohm files)",
  "version": "0.1.0",
  "publisher": "ResistProject",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "ohm",
        "aliases": [
          "Ohm",
          "ohm"
        ],
        "extensions": [
          ".ohm"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "../public/ohm.png",
          "dark": "../public/ohm.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "ohm",
        "scopeName": "source.ohm",
        "path": "./syntaxes/ohm.tmLanguage.json"
      }
    ]
  }
}
