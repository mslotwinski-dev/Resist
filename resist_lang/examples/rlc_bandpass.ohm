// Zamknięty obwód RLC (Szeregowy)
// Obwód uderzony skokiem napięcia z zerowymi warunkami początkowymi - wzbudza oscylacje typu "ringing".

let v_step = StepSource(in, gnd, 0, 5, 10u).pos(3, 4).rot(90)
let r_damp = Resistor(in, node_l, 10).pos(6, 3)
let l_tank = Inductor(node_l, out, 1m).pos(10, 3)
let c_tank = Capacitor(out, gnd, 1u).pos(14, 4).rot(90)

// 3. Widoczne przeregulowanie z powodu małego tłumienia
analyze.transient(stop: 1m, step: 1u)
