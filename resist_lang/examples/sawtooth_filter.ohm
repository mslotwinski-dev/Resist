// Sawtooth Filter Example
// Utilizes FuncVSource to generate a 1kHz sawtooth wave using Modulo math.
// Formula: (t % 1ms) * 5000 — ramps 0 to 5V every 1ms.

// 1kHz Sawtooth Source
let vsaw = FuncVSource(input, gnd, |t| { (t % 1m) * 5000 }).pos(50, 150).rot(90)

// RC Low-Pass Filter
let r1 = Resistor(input, output, 1k).pos(150, 80)
let c1 = Capacitor(output, gnd, 100n).pos(250, 150).rot(90)

// Run Transient Analysis for 5ms to see 5 full periods
analyze.transient(stop: 5m, step: 10u)
